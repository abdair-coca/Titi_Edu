# ─── PostgreSQL (Prisma) ───────────────────────────────────────────────
# Local: postgresql://USER:PASSWORD@localhost:5432/titi
# Prod (Railway): usar la DATABASE_URL del Postgres administrado.
DATABASE_URL="postgresql://user:password@localhost:5432/titi"

# ─── Neo4j (Aura o local) ──────────────────────────────────────────────
NEO4J_URI=neo4j+s://XXXX.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=tu_password_de_aura

# ─── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=neosocial_secret_2026_cambiar_en_produccion

# ─── Servidor ──────────────────────────────────────────────────────────
PORT=3001

# Orígenes adicionales permitidos por CORS (separados por coma).
# Localhost siempre está permitido; aquí va el dominio de producción.
# Admite varias URLs para incluir previews de Vercel:
#   FRONTEND_URL=https://titiedu.vercel.app,https://titiedu-git-dev.vercel.app
FRONTEND_URL=https://titiedu.vercel.app

# ─── Cloudinary (storage de imágenes/materiales) ───────────────────────
# Sin estas credenciales, las subidas caen a disco local (solo dev).
# En prod son obligatorias (Railway tiene filesystem efímero).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Seed (opcional) ───────────────────────────────────────────────────
# Password de las cuentas demo que crea `npm run seed`.
SEED_PASSWORD=titi1234
